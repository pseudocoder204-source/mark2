# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.mypy_cache/
.pytest_cache/

# ---- Local editor / tool state ----
.claude/settings.local.json
.vscode/
.idea/

# ---- Generated artifacts ----
graph.png

# ---- Databases (never commit) ----
# vulnerability_cache.db is 3.2 GB and hosted externally (see CONTRIBUTING_SCAN_DATA.md).
# trainset.db + clamav_manifest.db are per-user local state, created on first run.
*.db
*.db.gz

# ---- Per-user scan outputs / logs (contain hostnames, file paths) ----
contrib_*.json
report_training_log.jsonl
clamav_*.json
clamav_*.log
clamav_full_scan_log
*.log

# ---- Exported training data (once real scans are merged in, these carry real
# hostnames/IPs/file paths from trainset.db — regenerate locally via
# export_trainset.py, never publish) ----
finetune/train.jsonl
finetune/eval.jsonl
finetune/train_triage.jsonl
finetune/eval_triage.jsonl

# ---- Internal planning / scratch notes (not for the public repo) ----
notes/

# ---- Virtualenvs ----
finetune/venv/

# ---- Fine-tune build artifacts (multi-GB binaries / compiler cache — never commit) ----
finetune/gguf_out/
finetune/gguf_out_v2/
unsloth_compiled_cache/

# ---- Eval run outputs (regenerable, contain raw LLM generations) ----
finetune/eval_outputs.json
finetune/eval_scores.json
finetune/eval_ollama_*.json
